# ─── TG Stream Server — Environment Config ──────────────

# ─── Telegram Credentials ───────────────────────────────
API_ID=12345678
API_HASH=your_api_hash_from_my_telegram_org
BOT_TOKEN=your_bot_token_here
CHANNEL_ID=-100XXXXXXXXXX

# ─── Database ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASS=your_database_password

# ─── Stream Server ─────────────────────────────────────
STREAM_SECRET=change_me_to_a_random_64_char_hex_string
STREAM_BASE_URL=https://your-app.onrender.com
STREAM_HOST=0.0.0.0
STREAM_PORT=8080

# ─── Admin ─────────────────────────────────────────────
# Your Telegram user ID (Main Admin — full control)
# Send /start to @userinfobot to get it
MAIN_ADMIN_TELEGRAM_ID=0

# Password for /admin web panel login
ADMIN_PASSWORD=your_secure_admin_password

# Secret path for admin panel URL (e.g. admin panel will be at /admin/{path}/)
ADMIN_SECRET_PATH=your_random_secret_path

# ─── Security ──────────────────────────────────────────
TOKEN_LIFETIME=14400
ALLOWED_ORIGINS=*
CHUNK_SIZE=1048576
MAX_STREAMS_PER_IP=5
